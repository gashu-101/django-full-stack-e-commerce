# =============================================================================
# Nova — environment template. Copy to .env and fill in your real values.
# =============================================================================

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
SITE_URL=http://127.0.0.1:8000
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# -----------------------------------------------------------------------------
# SMTP / Email
# -----------------------------------------------------------------------------
# Gmail example (use an App Password, not your account password):
#   https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=you@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
DEFAULT_FROM_EMAIL=Nova Studio <you@gmail.com>
ADMIN_EMAIL=you@gmail.com

# If EMAIL_HOST / EMAIL_HOST_USER are blank, Nova falls back to the console
# backend (emails print to the terminal) — perfect for local dev.

# -----------------------------------------------------------------------------
# Chapa — https://dashboard.chapa.co/  →  Settings → API
# -----------------------------------------------------------------------------
CHAPA_SECRET_KEY=CHASECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxx
CHAPA_PUBLIC_KEY=CHAPUBK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxx
CHAPA_BASE_URL=https://api.chapa.co/v1
CHAPA_CURRENCY=ETB
# USD prices × CHAPA_FX_RATE = ETB amount sent to Chapa
CHAPA_FX_RATE=135.0
# After your store has live webhooks, set this to the secret Chapa generates
CHAPA_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Crypto via NOWPayments — https://account.nowpayments.io/store-settings
# -----------------------------------------------------------------------------
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_BASE_URL=https://api.nowpayments.io/v1
NOWPAYMENTS_PRICE_CURRENCY=usd
